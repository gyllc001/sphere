# Copy this file to .env.test and fill in values before running integration tests.
# NEVER commit .env.test — it contains real credentials.

# Separate test database (must not be the production database)
TEST_DATABASE_URL=postgresql://user:password@localhost:5432/sphere_test

# JWT secret — can match dev secret for local tests, but use a different value in CI
JWT_SECRET=test-jwt-secret-change-me

# Optional: suppress email sending during tests (set to any non-empty value)
DISABLE_EMAIL=true

# Anthropic key for AI matching/negotiation tests (use a low-quota test key)
ANTHROPIC_API_KEY=sk-ant-...
