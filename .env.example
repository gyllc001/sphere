# =============================================================================
# Sphere Environment Configuration
# Copy to .env.local for local development
# =============================================================================

# ---- App ----
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# ---- Database (PostgreSQL via Neon) ----
DATABASE_URL=postgresql://user:password@localhost:5432/sphere_dev

# ---- Auth ----
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d
NEXTAUTH_SECRET=change-me-nextauth-secret
NEXTAUTH_URL=http://localhost:3000

# ---- API ----
PORT=4000
ALLOWED_ORIGINS=http://localhost:3000

# ---- AI (for matching + negotiation agents) ----
ANTHROPIC_API_KEY=sk-ant-...

# ---- File Storage ----
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---- Email ----
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@sphere.app

# ---- Analytics (PostHog) ----
# Frontend (Next.js) — expose publicly
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Backend (API) — server-side only
POSTHOG_KEY=phc_...
POSTHOG_HOST=https://us.i.posthog.com
